---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../lib/paths';
---

<Layout title="Page Not Found" description="The requested CPIL page could not be found.">
  <section class="section-shell grid min-h-[55vh] place-items-center py-16 text-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">404</p>
      <h1 class="mt-3 text-4xl font-bold text-[rgb(var(--ink))]">Page not found</h1>
      <p class="mt-4 text-[rgb(var(--muted))]">The page may have moved or has not been published yet.</p>
      <a
        href={withBase('/')}
        class="mt-8 inline-flex min-h-11 items-center rounded-md bg-[rgb(var(--accent-strong))] px-5 py-3 text-sm font-bold text-white no-underline"
      >
        Return home
      </a>
    </div>
  </section>
</Layout>
