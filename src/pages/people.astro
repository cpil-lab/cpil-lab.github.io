---
import { getCollection } from 'astro:content';
import PersonCard from '../components/PersonCard.astro';
import Layout from '../layouts/Layout.astro';
import { roleOrder, siteInfo } from '../data/site';

const people = (await getCollection('people')).sort((a, b) => {
  const roleDelta = roleOrder.indexOf(a.data.role) - roleOrder.indexOf(b.data.role);
  return roleDelta || a.data.order - b.data.order || a.data.name.localeCompare(b.data.name);
});
const grouped = roleOrder.map((role) => ({
  role,
  people: people.filter((person) => person.data.role === role),
}));
---

<Layout title="People" description="Members, alumni, and collaborators of the Cyber-Physical Intelligence Lab.">
  <section class="section-shell py-14">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">People</p>
    <h1 class="mt-3 text-4xl font-bold text-[rgb(var(--ink))]">CPIL members</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">
      {siteInfo.name} is led by {siteInfo.director} with collaborators and students across {siteInfo.platforms.join(', ')}.
    </p>
  </section>

  <section class="section-shell grid gap-12">
    {
      grouped
        .filter((group) => group.people.length > 0)
        .map((group) => (
          <div>
            <div class="mb-5 flex items-end justify-between gap-4 border-b border-[rgba(var(--line),0.78)] pb-3">
              <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">{group.role}</h2>
              <p class="text-sm text-[rgb(var(--muted))]">{group.people.length} profile{group.people.length === 1 ? '' : 's'}</p>
            </div>
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {group.people.map((person) => <PersonCard person={person} />)}
            </div>
          </div>
        ))
    }
  </section>
</Layout>
