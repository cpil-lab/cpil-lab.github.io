---
import { getCollection } from 'astro:content';
import PersonCard from '../components/PersonCard.astro';
import Layout from '../layouts/Layout.astro';
import { roleOrder, siteInfo } from '../data/site';

const normalizeRole = (role: string) => (role === 'Director' || role === 'PI' ? 'Principal Investigator' : role);
const getRoleRank = (role: string) => {
  const rank = roleOrder.indexOf(normalizeRole(role) as (typeof roleOrder)[number]);
  return rank === -1 ? roleOrder.length : rank;
};

const people = (await getCollection('people')).sort((a, b) => {
  const roleDelta = getRoleRank(a.data.role) - getRoleRank(b.data.role);
  return roleDelta || a.data.order - b.data.order || a.data.name.localeCompare(b.data.name);
});
const extraRoles = Array.from(
  new Set(people.map((person) => normalizeRole(person.data.role)).filter((role) => !roleOrder.includes(role as (typeof roleOrder)[number]))),
).sort();
const grouped = [...roleOrder, ...extraRoles].map((role) => ({
  role,
  people: people.filter((person) => normalizeRole(person.data.role) === role),
}));
---

<Layout title="People" description="Members, students, researchers, and collaborators of the Cyber-Physical Intelligence Lab.">
  <section class="section-shell py-10">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">People</p>
    <h1 class="mt-3 text-3xl font-bold text-[rgb(var(--ink))]">CPIL members</h1>
    <p class="mt-4 max-w-3xl text-base leading-7 text-[rgb(var(--muted))]">
      {siteInfo.name} is led by {siteInfo.director} with students, researchers, and collaborators across {siteInfo.platforms.join(', ')}.
    </p>
  </section>

  <section class="section-shell grid gap-8">
    {
      grouped
        .filter((group) => group.people.length > 0)
        .map((group) => (
          <div>
            <div class="mb-4 flex items-end justify-between gap-4 border-b border-[rgba(var(--line),0.78)] pb-2">
              <h2 class="text-xl font-bold text-[rgb(var(--ink))]">{group.role}</h2>
              <p class="text-sm text-[rgb(var(--muted))]">{group.people.length} profile{group.people.length === 1 ? '' : 's'}</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {group.people.map((person) => <PersonCard person={person} />)}
            </div>
          </div>
        ))
    }
  </section>

  <section class="section-shell py-10">
    <article class="card p-5">
      <h2 class="text-xl font-bold text-[rgb(var(--ink))]">Update a profile</h2>
      <p class="mt-3 text-sm leading-7 text-[rgb(var(--muted))]">
        Profiles are Markdown files in <code>src/content/people</code>. Contributors can update or add profiles through GitHub pull requests, and Decap CMS open authoring is configured to submit outside edits as PRs for maintainer review.
      </p>
    </article>
  </section>
</Layout>
