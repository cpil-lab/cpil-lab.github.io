---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import TagFilter from '../components/TagFilter.astro';
import Layout from '../layouts/Layout.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const topics = Array.from(new Set(projects.flatMap((project) => project.data.tags))).sort();
---

<Layout title="Projects" description="Detailed CPIL research project and direction listings across AI, cyber-physical systems, efficient inference, agentic AI, and intelligent infrastructure.">
  <section class="section-shell py-14">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">Projects</p>
    <h1 class="mt-3 text-4xl font-bold text-[rgb(var(--ink))]">Research projects and directions</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">
      Browse CPIL research directions and project records by topic and status. Each entry is stored as Markdown so collaborators can improve descriptions through pull requests.
    </p>
  </section>

  <section class="section-shell grid gap-8">
    <div class="card grid gap-5 p-5 md:grid-cols-[1fr_auto] md:items-end">
      <TagFilter label="Topic" name="topic" options={topics} />
      <label class="grid gap-2 text-sm font-semibold text-[rgb(var(--ink))]">
        Status
        <select
          id="project-status-filter"
          class="min-h-11 rounded-md border border-[rgba(var(--line),0.95)] bg-[rgb(var(--surface-raised))] px-3 text-sm text-[rgb(var(--ink))]"
        >
          <option value="all">All</option>
          <option value="active">Active</option>
          <option value="completed">Completed</option>
        </select>
      </label>
    </div>

    <div id="project-grid" class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <p id="project-empty" class="hidden rounded-md border border-[rgba(var(--line),0.9)] p-5 text-sm text-[rgb(var(--muted))]">
      No projects match the selected filters.
    </p>
  </section>
</Layout>

<script is:inline>
  (() => {
    const state = { topic: 'all', status: 'all' };
    const cards = Array.from(document.querySelectorAll('.project-card'));
    const empty = document.getElementById('project-empty');
    const status = document.getElementById('project-status-filter');

    const setActiveButton = (group, value) => {
      group.querySelectorAll('.filter-button').forEach((button) => {
        const active = button.dataset.filterValue === value;
        button.setAttribute('aria-pressed', String(active));
        button.classList.toggle('bg-[rgb(var(--ink))]', active);
        button.classList.toggle('text-[rgb(var(--surface))]', active);
        button.classList.toggle('text-[rgb(var(--muted))]', !active);
      });
    };

    const applyFilters = () => {
      let visible = 0;
      cards.forEach((card) => {
        const tags = card.dataset.tags || '';
        const matchesTopic = state.topic === 'all' || tags.split('|').includes(state.topic);
        const matchesStatus = state.status === 'all' || card.dataset.status === state.status;
        const show = matchesTopic && matchesStatus;
        card.classList.toggle('hidden', !show);
        if (show) visible += 1;
      });
      empty?.classList.toggle('hidden', visible > 0);
    };

    document.querySelectorAll('[data-filter-group="topic"]').forEach((group) => {
      group.addEventListener('click', (event) => {
        const target = event.target.closest('.filter-button');
        if (!target) return;
        state.topic = target.dataset.filterValue || 'all';
        setActiveButton(group, state.topic);
        applyFilters();
      });
    });

    status?.addEventListener('change', () => {
      state.status = status.value;
      applyFilters();
    });
  })();
</script>
