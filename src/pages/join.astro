---
import { ArrowRight, CheckCircle2, Mail } from 'lucide-astro';
import Layout from '../layouts/Layout.astro';
import { openPositions, siteInfo } from '../data/site';
---

<Layout title="Join Us" description="Open CPIL opportunities for PhD students, postdocs, visiting scholars, and research interns.">
  <section class="section-shell py-14">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">Join Us</p>
    <h1 class="mt-3 max-w-4xl text-4xl font-bold leading-tight text-[rgb(var(--ink))]">
      Work on intelligent systems that meet real infrastructure.
    </h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">
      CPIL is open to PhD students, postdoctoral researchers, visiting scholars, and research interns interested in AI for systems, networks, cyber-physical intelligence, and applied machine learning.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={`mailto:${siteInfo.contactEmail}?subject=CPIL%20application%20inquiry`}
        class="inline-flex min-h-11 items-center gap-2 rounded-md bg-[rgb(var(--accent-strong))] px-5 py-3 text-sm font-bold text-white no-underline"
      >
        Contact CPIL
        <Mail class="size-4" aria-hidden="true" />
      </a>
      <a
        href="#how-to-apply"
        class="inline-flex min-h-11 items-center gap-2 rounded-md border border-[rgba(var(--line),0.95)] bg-[rgb(var(--surface-raised))] px-5 py-3 text-sm font-bold text-[rgb(var(--ink))] no-underline"
      >
        How to apply
        <ArrowRight class="size-4" aria-hidden="true" />
      </a>
    </div>
  </section>

  <section class="border-y border-[rgba(var(--line),0.78)] bg-[rgb(var(--surface-raised))] py-14">
    <div class="section-shell">
      <h2 class="text-3xl font-bold text-[rgb(var(--ink))]">Open positions</h2>
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          openPositions.map((position) => (
            <article class="card p-5">
              <CheckCircle2 class="size-5 text-[rgb(var(--accent-strong))]" aria-hidden="true" />
              <h3 class="mt-4 text-lg font-bold text-[rgb(var(--ink))]">{position}</h3>
              <p class="mt-3 text-sm leading-6 text-[rgb(var(--muted))]">
                Candidates should be motivated by careful research, systems thinking, and collaborative engineering.
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell grid gap-8 py-14 lg:grid-cols-3">
    <article class="card p-6">
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Expected background</h2>
      <ul class="mt-5 grid gap-3 text-sm leading-6 text-[rgb(var(--muted))]">
        <li>Machine learning, systems, networking, optimization, control, or related areas.</li>
        <li>Strong programming skills and comfort building reproducible research artifacts.</li>
        <li>Interest in cyber-physical systems, communication networks, IoT, or infrastructure-scale AI.</li>
      </ul>
    </article>

    <article id="how-to-apply" class="card p-6">
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">How to apply</h2>
      <ul class="mt-5 grid gap-3 text-sm leading-6 text-[rgb(var(--muted))]">
        <li>Send a brief research statement describing interests and fit with CPIL.</li>
        <li>Include a CV, transcript if applicable, and representative publications or project links.</li>
        <li>For exact program requirements, follow the relevant MBZUAI, McGill University, or Mila application process.</li>
      </ul>
    </article>

    <article class="card p-6">
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Contact</h2>
      <p class="mt-5 text-sm leading-6 text-[rgb(var(--muted))]">
        Use the lab contact email for initial inquiries, collaboration questions, and application fit discussions.
      </p>
      <a href={`mailto:${siteInfo.contactEmail}`} class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-[rgb(var(--accent-strong))]">
        {siteInfo.contactEmail}
        <Mail class="size-4" aria-hidden="true" />
      </a>
    </article>
  </section>
</Layout>
