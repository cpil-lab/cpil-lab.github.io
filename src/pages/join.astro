---
import { ArrowRight, Mail } from 'lucide-astro';
import WeChatBlock from '../components/WeChatBlock.astro';
import Layout from '../layouts/Layout.astro';
import { applicantInterests, applicationMaterials, openPositions, recruitmentContacts, siteInfo } from '../data/site';
---

<Layout title="Join CPIL" description="Open CPIL opportunities for students, postdocs, visiting scholars, research interns, academic collaborators, and industry partners.">
  <section class="section-shell py-14">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">Join CPIL</p>
    <h1 class="mt-3 max-w-4xl text-4xl font-bold leading-tight text-[rgb(var(--ink))]">
      We welcome talented students and researchers interested in building trustworthy, efficient, and agentic AI systems for the cyber-physical world.
    </h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">
      CPIL is actively recruiting motivated PhD students, postdoctoral researchers, visiting scholars, and research interns. The lab operates across {siteInfo.platforms.join(', ')} and maintains active academic and industrial collaborations.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={`mailto:${siteInfo.contactEmail}?subject=CPIL%20recruitment%20and%20collaboration%20inquiry`}
        class="inline-flex min-h-11 items-center gap-2 rounded-md bg-[rgb(var(--accent-strong))] px-5 py-3 text-sm font-semibold text-white no-underline"
      >
        Email CPIL
        <Mail class="size-4" aria-hidden="true" />
      </a>
      <a
        href="#how-to-apply"
        class="inline-flex min-h-11 items-center gap-2 rounded-md border border-[rgba(var(--line),0.95)] bg-[rgb(var(--surface-raised))] px-5 py-3 text-sm font-semibold text-[rgb(var(--ink))] no-underline"
      >
        How to apply
        <ArrowRight class="size-4" aria-hidden="true" />
      </a>
    </div>
  </section>

  <section class="border-y border-[rgba(var(--line),0.78)] bg-[rgb(var(--surface-raised))] py-14">
    <div class="section-shell">
      <h2 class="text-3xl font-bold text-[rgb(var(--ink))]">Open roles</h2>
      <div class="mt-8 grid gap-px overflow-hidden rounded-md border border-[rgba(var(--line),0.9)] bg-[rgba(var(--line),0.9)] md:grid-cols-2 lg:grid-cols-3">
        {
          openPositions.map((position) => (
            <article class="bg-[rgb(var(--surface-raised))] p-5">
              <h3 class="text-lg font-bold text-[rgb(var(--ink))]">{position}</h3>
              <p class="mt-3 text-sm leading-6 text-[rgb(var(--muted))]">
                Candidates should be motivated by careful research, systems thinking, and collaborative engineering.
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell grid gap-8 py-14 lg:grid-cols-[1fr_0.85fr]">
    <article id="how-to-apply" class="card p-6">
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">How to apply</h2>
      <p class="mt-5 text-sm leading-7 text-[rgb(var(--muted))]">
        Prospective applicants are encouraged to send a concise email with the following materials.
      </p>
      <ul class="mt-5 grid gap-3 text-sm leading-6 text-[rgb(var(--muted))]">
        {applicationMaterials.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="card p-6">
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Recruitment and collaboration contacts</h2>
      <div class="mt-5 grid gap-4">
        {
          recruitmentContacts.map((contact) => (
            <div>
              <p class="text-sm font-semibold text-[rgb(var(--ink))]">{contact.name}</p>
              <a href={`mailto:${contact.email}`} class="text-sm font-semibold text-[rgb(var(--accent-strong))]">
                {contact.email}
              </a>
            </div>
          ))
        }
      </div>
    </article>
  </section>

  <section class="section-shell grid gap-8 lg:grid-cols-[1fr_0.8fr]">
    <article class="card p-6">
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Research interests for applicants</h2>
      <ul class="mt-5 flex flex-wrap gap-2" aria-label="Applicant research interests">
        {
          applicantInterests.map((interest) => (
            <li class="rounded-md bg-[rgba(var(--accent),0.09)] px-2.5 py-1 text-xs font-semibold text-[rgb(var(--accent-strong))]">
              {interest}
            </li>
          ))
        }
      </ul>
    </article>

    <WeChatBlock />
  </section>
</Layout>
