---
import { Mail, MapPin } from 'lucide-astro';
import WeChatBlock from '../components/WeChatBlock.astro';
import Layout from '../layouts/Layout.astro';
import { recruitmentContacts, siteInfo } from '../data/site';
---

<Layout title="Contact CPIL" description="Contact information for recruitment, visiting opportunities, internships, academic exchange, and project collaboration with CPIL.">
  <section class="section-shell py-14">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">Contact CPIL</p>
    <h1 class="mt-3 text-4xl font-bold text-[rgb(var(--ink))]">Recruitment and collaboration</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">
      The Cyber-Physical Intelligence Lab welcomes inquiries from prospective students, postdoctoral researchers, visiting scholars, research interns, academic collaborators, and industry partners.
    </p>
  </section>

  <section class="section-shell grid gap-6 lg:grid-cols-[1fr_0.85fr]">
    <article class="card p-6">
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Lab contact</h2>
      <p class="mt-5 text-sm font-semibold leading-7 text-[rgb(var(--ink))]">
        {siteInfo.name}<br />
        {siteInfo.platforms.join(' · ')}
      </p>
      <p class="mt-5 text-sm leading-7 text-[rgb(var(--muted))]">
        For recruitment, visiting opportunities, internships, academic exchange, and project collaboration, please contact the CPIL team by email or through the CPIL WeChat official account.
      </p>
      <div class="mt-6 grid gap-4">
        {
          recruitmentContacts.map((contact) => (
            <div>
              <p class="text-sm font-semibold text-[rgb(var(--ink))]">{contact.name}</p>
              <a href={`mailto:${contact.email}`} class="inline-flex items-center gap-2 text-sm font-semibold text-[rgb(var(--accent-strong))]">
                <Mail class="size-4" aria-hidden="true" />
                {contact.email}
              </a>
            </div>
          ))
        }
        <div class="border-t border-[rgba(var(--line),0.78)] pt-4">
          <p class="text-sm font-semibold text-[rgb(var(--ink))]">Website support</p>
          <a href={`mailto:${siteInfo.websiteSupportEmail}`} class="inline-flex items-center gap-2 text-sm font-semibold text-[rgb(var(--accent-strong))]">
            <Mail class="size-4" aria-hidden="true" />
            {siteInfo.websiteSupportEmail}
          </a>
        </div>
      </div>
    </article>

    <WeChatBlock />
  </section>

  <section class="section-shell mt-8 grid gap-6 md:grid-cols-3">
    {
      siteInfo.platforms.map((platform) => (
        <article class="card p-6">
          <MapPin class="size-5 text-[rgb(var(--accent-strong))]" aria-hidden="true" />
          <h2 class="mt-4 text-2xl font-bold text-[rgb(var(--ink))]">{platform}</h2>
          <p class="mt-3 text-sm leading-7 text-[rgb(var(--muted))]">CPIL research presence and collaboration platform.</p>
        </article>
      ))
    }
  </section>
</Layout>
