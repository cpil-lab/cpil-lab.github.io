---
import { Mail, MapPin } from 'lucide-astro';
import Layout from '../layouts/Layout.astro';
import { siteInfo } from '../data/site';
---

<Layout title="Contact" description="Contact information and platform affiliations for CPIL, the Cyber-Physical Intelligence Lab.">
  <section class="section-shell py-14">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">Contact</p>
    <h1 class="mt-3 text-4xl font-bold text-[rgb(var(--ink))]">Get in touch</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">
      CPIL connects research activity across {siteInfo.platforms.join(', ')}.
    </p>
  </section>

  <section class="section-shell grid gap-6 lg:grid-cols-4">
    <article class="card p-6">
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Lab contact</h2>
      <a href={`mailto:${siteInfo.contactEmail}`} class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-[rgb(var(--accent-strong))]">
        <Mail class="size-4" aria-hidden="true" />
        {siteInfo.contactEmail}
      </a>
      <p class="mt-5 text-sm leading-7 text-[rgb(var(--muted))]">
        For applications, collaboration inquiries, and media requests, include a clear subject line and relevant context.
      </p>
    </article>

    {
      siteInfo.platforms.map((platform) => (
        <article class="card p-6">
          <MapPin class="size-5 text-[rgb(var(--accent-strong))]" aria-hidden="true" />
          <h2 class="mt-4 text-2xl font-bold text-[rgb(var(--ink))]">{platform}</h2>
          <p class="mt-3 text-sm leading-7 text-[rgb(var(--muted))]">Platform affiliation listed by CPIL.</p>
        </article>
      ))
    }
  </section>
</Layout>
