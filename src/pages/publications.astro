---
import { getCollection } from 'astro:content';
import PublicationItem from '../components/PublicationItem.astro';
import TagFilter from '../components/TagFilter.astro';
import Layout from '../layouts/Layout.astro';

const publications = (await getCollection('publications')).sort((a, b) => {
  return b.data.year - a.data.year || a.data.title.localeCompare(b.data.title);
});
const years = Array.from(new Set(publications.map((publication) => publication.data.year))).sort((a, b) => b - a);
const types = Array.from(new Set(publications.map((publication) => publication.data.type))).sort();
const topics = Array.from(new Set(publications.flatMap((publication) => publication.data.tags))).sort();
---

<Layout title="Publications" description="Searchable CPIL publications with year, type, topic filters, paper links, code links, project links, and BibTeX copy buttons.">
  <section class="section-shell py-14">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">Publications</p>
    <h1 class="mt-3 text-4xl font-bold text-[rgb(var(--ink))]">Research outputs</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">
      Browse CPIL publication records by year, topic, and type, with links to related papers, code, projects, and citation metadata.
    </p>
  </section>

  <section class="section-shell grid gap-8">
    <div class="card grid gap-5 p-5">
      <label class="grid gap-2 text-sm font-semibold text-[rgb(var(--ink))]">
        Search
        <input
          id="publication-search"
          type="search"
          placeholder="Search title, author, venue, topic..."
          class="min-h-11 rounded-md border border-[rgba(var(--line),0.95)] bg-[rgb(var(--surface-raised))] px-3 text-sm text-[rgb(var(--ink))] placeholder:text-[rgb(var(--muted))]"
        />
      </label>
      <div class="grid gap-5 lg:grid-cols-[1fr_auto_auto] lg:items-end">
        <TagFilter label="Topic" name="publication-topic" options={topics} />
        <label class="grid gap-2 text-sm font-semibold text-[rgb(var(--ink))]">
          Year
          <select
            id="publication-year-filter"
            class="min-h-11 rounded-md border border-[rgba(var(--line),0.95)] bg-[rgb(var(--surface-raised))] px-3 text-sm text-[rgb(var(--ink))]"
          >
            <option value="all">All years</option>
            {years.map((year) => <option value={String(year)}>{year}</option>)}
          </select>
        </label>
        <label class="grid gap-2 text-sm font-semibold text-[rgb(var(--ink))]">
          Type
          <select
            id="publication-type-filter"
            class="min-h-11 rounded-md border border-[rgba(var(--line),0.95)] bg-[rgb(var(--surface-raised))] px-3 text-sm text-[rgb(var(--ink))]"
          >
            <option value="all">All types</option>
            {types.map((type) => <option value={type}>{type}</option>)}
          </select>
        </label>
      </div>
      <p id="publication-count" class="text-sm text-[rgb(var(--muted))]">{publications.length} publications shown</p>
    </div>

    <div id="publication-list" class="grid gap-5">
      {publications.map((publication) => <PublicationItem publication={publication} />)}
    </div>
    <p id="publication-empty" class="hidden rounded-md border border-[rgba(var(--line),0.9)] p-5 text-sm text-[rgb(var(--muted))]">
      No publications match the selected filters.
    </p>
  </section>
</Layout>

<script is:inline>
  (() => {
    const state = { topic: 'all', year: 'all', type: 'all', search: '' };
    const items = Array.from(document.querySelectorAll('.publication-item'));
    const empty = document.getElementById('publication-empty');
    const count = document.getElementById('publication-count');
    const search = document.getElementById('publication-search');
    const year = document.getElementById('publication-year-filter');
    const type = document.getElementById('publication-type-filter');

    const setActiveButton = (group, value) => {
      group.querySelectorAll('.filter-button').forEach((button) => {
        const active = button.dataset.filterValue === value;
        button.setAttribute('aria-pressed', String(active));
        button.classList.toggle('bg-[rgb(var(--ink))]', active);
        button.classList.toggle('text-[rgb(var(--surface))]', active);
        button.classList.toggle('text-[rgb(var(--muted))]', !active);
      });
    };

    const applyFilters = () => {
      let visible = 0;
      items.forEach((item) => {
        const tags = item.dataset.tags || '';
        const searchable = item.dataset.search || '';
        const matchesTopic = state.topic === 'all' || tags.split('|').includes(state.topic);
        const matchesYear = state.year === 'all' || item.dataset.year === state.year;
        const matchesType = state.type === 'all' || item.dataset.type === state.type;
        const matchesSearch = !state.search || searchable.includes(state.search);
        const show = matchesTopic && matchesYear && matchesType && matchesSearch;
        item.classList.toggle('hidden', !show);
        if (show) visible += 1;
      });
      empty?.classList.toggle('hidden', visible > 0);
      if (count) count.textContent = `${visible} publication${visible === 1 ? '' : 's'} shown`;
    };

    document.querySelectorAll('[data-filter-group="publication-topic"]').forEach((group) => {
      group.addEventListener('click', (event) => {
        const target = event.target.closest('.filter-button');
        if (!target) return;
        state.topic = target.dataset.filterValue || 'all';
        setActiveButton(group, state.topic);
        applyFilters();
      });
    });

    search?.addEventListener('input', () => {
      state.search = search.value.trim().toLowerCase();
      applyFilters();
    });

    year?.addEventListener('change', () => {
      state.year = year.value;
      applyFilters();
    });

    type?.addEventListener('change', () => {
      state.type = type.value;
      applyFilters();
    });

    document.querySelectorAll('.copy-bibtex').forEach((button) => {
      button.addEventListener('click', async () => {
        const bibtex = button.dataset.bibtex || '';
        const label = button.querySelector('.copy-label');
        try {
          await navigator.clipboard.writeText(bibtex);
          if (label) label.textContent = 'Copied';
          window.setTimeout(() => {
            if (label) label.textContent = 'Copy BibTeX';
          }, 1800);
        } catch {
          if (label) label.textContent = 'Copy failed';
        }
      });
    });
  })();
</script>
