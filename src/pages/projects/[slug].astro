---
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ArrowUpRight } from 'lucide-astro';
import Layout from '../../layouts/Layout.astro';
import { externalUrl, withBase } from '../../lib/paths';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  shortDescription,
  longDescription,
  leaders,
  members,
  tags,
  image,
  links,
  publications,
  impactHolders,
  status,
} = project.data;
const imageIsIcon = image.toLowerCase().endsWith('.svg') || image.toLowerCase().includes('logo');
---

<Layout title={title} description={shortDescription} image={image}>
  <section class="border-b border-[rgba(var(--line),0.78)] bg-[rgb(var(--surface-raised))]">
    <div class="section-shell grid gap-10 py-12 lg:grid-cols-[minmax(0,1fr)_minmax(16rem,0.42fr)] lg:items-center">
      <div>
        <a href={withBase('/projects/')} class="inline-flex items-center gap-2 text-sm font-semibold text-[rgb(var(--accent-strong))]">
          <ArrowLeft class="size-4" aria-hidden="true" />
          Projects
        </a>
        <p class="mt-8 text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">Project</p>
        <h1 class="mt-3 text-4xl font-bold leading-tight text-[rgb(var(--ink))]">{title}</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">{shortDescription}</p>
        {
          tags.length > 0 && (
            <ul class="mt-6 flex flex-wrap gap-2" aria-label={`${title} topics`}>
              {tags.map((tag) => (
                <li class="rounded-md bg-[rgba(var(--accent),0.1)] px-2.5 py-1 text-xs font-semibold text-[rgb(var(--accent-strong))]">
                  {tag}
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <figure class:list={[
        'grid gap-3',
        imageIsIcon ? 'max-w-xs justify-self-center lg:justify-self-end' : '',
      ]}>
        <img
          src={withBase(image)}
          alt={`Visualization for ${title}`}
          class:list={[
            'w-full rounded-md border border-[rgba(var(--line),0.86)] bg-[#f5f5f7]',
            imageIsIcon ? 'aspect-square p-8 object-contain' : 'aspect-[16/10] object-cover',
          ]}
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <section class="section-shell grid gap-8 py-12 lg:grid-cols-[1fr_18rem] lg:items-start">
    <article class="grid gap-8">
      <section class="card p-6">
        <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Overview</h2>
        <p class="mt-4 text-base leading-8 text-[rgb(var(--muted))]">{longDescription}</p>
      </section>

      <section class="project-content">
        <Content />
      </section>

      <section class="grid gap-5 lg:grid-cols-2">
        <article class="card p-6">
          <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Related Publications</h2>
          {
            publications.length > 0 ? (
              <ul class="mt-5 grid gap-4">
                {publications.map((publication) => (
                  <li class="border-t border-[rgba(var(--line),0.82)] pt-4 first:border-t-0 first:pt-0">
                    <h3 class="text-base font-bold leading-6 text-[rgb(var(--ink))]">
                      {publication.url ? (
                        <a href={externalUrl(publication.url)} class="inline-flex items-start gap-1.5 text-inherit no-underline hover:text-[rgb(var(--accent-strong))]">
                          {publication.title}
                          <ArrowUpRight class="mt-1 size-4 shrink-0" aria-hidden="true" />
                        </a>
                      ) : (
                        publication.title
                      )}
                    </h3>
                    {
                      (publication.venue || publication.year) && (
                        <p class="mt-1 text-sm font-semibold text-[rgb(var(--warm))]">
                          {[publication.venue, publication.year].filter(Boolean).join(' · ')}
                        </p>
                      )
                    }
                    {publication.summary && <p class="mt-2 text-sm leading-6 text-[rgb(var(--muted))]">{publication.summary}</p>}
                  </li>
                ))}
              </ul>
            ) : (
              <p class="mt-4 text-sm leading-6 text-[rgb(var(--muted))]">
                Publication records will be added here as project outputs are released.
              </p>
            )
          }
        </article>

        <article class="card p-6">
          <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">Impact Holders</h2>
          {
            impactHolders.length > 0 ? (
              <ul class="mt-5 grid gap-4">
                {impactHolders.map((holder) => (
                  <li class="border-t border-[rgba(var(--line),0.82)] pt-4 first:border-t-0 first:pt-0">
                    <h3 class="text-base font-bold leading-6 text-[rgb(var(--ink))]">
                      {holder.url ? (
                        <a href={externalUrl(holder.url)} class="inline-flex items-start gap-1.5 text-inherit no-underline hover:text-[rgb(var(--accent-strong))]">
                          {holder.name}
                          <ArrowUpRight class="mt-1 size-4 shrink-0" aria-hidden="true" />
                        </a>
                      ) : (
                        holder.name
                      )}
                    </h3>
                    {holder.role && <p class="mt-1 text-sm font-semibold text-[rgb(var(--warm))]">{holder.role}</p>}
                    {holder.summary && <p class="mt-2 text-sm leading-6 text-[rgb(var(--muted))]">{holder.summary}</p>}
                  </li>
                ))}
              </ul>
            ) : (
              <p class="mt-4 text-sm leading-6 text-[rgb(var(--muted))]">
                Impact holders and user communities will be added as the project scope becomes clearer.
              </p>
            )
          }
        </article>
      </section>
    </article>

    <aside class="card grid gap-5 p-5">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.12em] text-[rgb(var(--warm))]">Status</p>
        <p class="mt-2 text-sm font-semibold capitalize text-[rgb(var(--ink))]">{status}</p>
      </div>
      {
        leaders.length > 0 && (
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-[rgb(var(--warm))]">Leadership</p>
            <p class="mt-2 text-sm leading-6 text-[rgb(var(--muted))]">{leaders.join(', ')}</p>
          </div>
        )
      }
      {
        members.length > 0 && (
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-[rgb(var(--warm))]">Members</p>
            <p class="mt-2 text-sm leading-6 text-[rgb(var(--muted))]">{members.join(', ')}</p>
          </div>
        )
      }
      {
        links.length > 0 && (
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-[rgb(var(--warm))]">Links</p>
            <div class="mt-3 grid gap-2 text-sm">
              {links.map((link) => (
                <a href={externalUrl(link.url)} class="inline-flex items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
                  {link.label}
                  <ArrowUpRight class="size-4" aria-hidden="true" />
                </a>
              ))}
            </div>
          </div>
        )
      }
    </aside>
  </section>
</Layout>

<style>
  .project-content {
    color: rgb(var(--muted));
    font-size: 1rem;
    line-height: 1.85;
  }

  .project-content :global(h2) {
    margin-top: 2rem;
    color: rgb(var(--ink));
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .project-content :global(h2:first-child) {
    margin-top: 0;
  }

  .project-content :global(h3) {
    margin-top: 1.5rem;
    color: rgb(var(--ink));
    font-size: 1.1rem;
    font-weight: 700;
  }

  .project-content :global(p),
  .project-content :global(ul),
  .project-content :global(ol) {
    margin-top: 0.9rem;
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    padding-left: 1.25rem;
  }

  .project-content :global(li + li) {
    margin-top: 0.35rem;
  }

  .project-content :global(a) {
    color: rgb(var(--accent-strong));
    font-weight: 650;
  }
</style>
