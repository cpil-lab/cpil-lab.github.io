---
import { getCollection } from 'astro:content';
import NewsCard from '../components/NewsCard.astro';
import Layout from '../layouts/Layout.astro';

const news = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="News" description="Conference news, research insights, recruitment updates, and technical highlights from the Cyber-Physical Intelligence Lab.">
  <section class="section-shell py-14">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">News</p>
    <h1 class="mt-3 text-4xl font-bold text-[rgb(var(--ink))]">Lab updates</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-[rgb(var(--muted))]">
      Conference news, research insights, recruitment opportunities, and technical highlights from CPIL.
    </p>
  </section>

  <section class="section-shell grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {news.map((item) => <NewsCard item={item} />)}
  </section>
</Layout>
