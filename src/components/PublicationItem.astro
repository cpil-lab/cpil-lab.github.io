---
import { Clipboard, ExternalLink } from 'lucide-astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  publication: CollectionEntry<'publications'>;
}

const { publication } = Astro.props;
const { title, authors, venue, year, type, abstract, badges, links, tags } = publication.data;
const searchable = [title, authors.join(' '), venue, year, type, badges.join(' '), tags.join(' ')].join(' ').toLowerCase();
const availableLinks = [
  links.paper ? 'paper' : '',
  links.code ? 'code' : '',
  links.project ? 'project' : '',
  links.bibtex ? 'bibtex' : '',
].filter(Boolean).join('|');
const searchableBadges = badges.join('|').toLowerCase();
---

<article
  class="publication-item card p-5"
  data-year={year}
  data-venue={venue.toLowerCase()}
  data-type={type}
  data-badges={searchableBadges}
  data-tags={tags.join('|').toLowerCase()}
  data-links={availableLinks}
  data-search={searchable}
>
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div>
      <h3 class="text-lg font-bold leading-7 text-[rgb(var(--ink))]">{title}</h3>
      <p class="mt-2 text-sm leading-6 text-[rgb(var(--muted))]">{authors.join(', ')}</p>
      <p class="mt-2 text-sm font-semibold text-[rgb(var(--ink))]">{venue}, {year}</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <span class="w-fit rounded-md bg-[rgba(var(--accent),0.11)] px-2.5 py-1 text-xs font-bold uppercase tracking-[0.08em] text-[rgb(var(--accent-strong))]">
        {type}
      </span>
      {
        badges.map((badge) => (
          <span class="w-fit rounded-md bg-[rgba(var(--warm),0.12)] px-2.5 py-1 text-xs font-bold uppercase tracking-[0.08em] text-[rgb(var(--warm))]">
            {badge}
          </span>
        ))
      }
    </div>
  </div>
  <p class="mt-4 text-sm leading-7 text-[rgb(var(--muted))]">{abstract}</p>
  {
    tags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2" aria-label={`${title} topics`}>
        {tags.map((tag) => (
          <li class="rounded-md bg-[rgba(var(--line),0.48)] px-2.5 py-1 text-xs font-semibold text-[rgb(var(--muted))]">
            {tag}
          </li>
        ))}
      </ul>
    )
  }
  <div class="mt-5 flex flex-wrap gap-3 text-sm">
    {
      links.paper && (
        <a href={links.paper} class="inline-flex items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
          Paper
          <ExternalLink class="size-4" aria-hidden="true" />
        </a>
      )
    }
    {
      links.code && (
        <a href={links.code} class="inline-flex items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
          Code
          <ExternalLink class="size-4" aria-hidden="true" />
        </a>
      )
    }
    {
      links.project && (
        <a href={links.project} class="inline-flex items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
          Project
          <ExternalLink class="size-4" aria-hidden="true" />
        </a>
      )
    }
    {
      links.bibtex && (
        <button
          type="button"
          class="copy-bibtex inline-flex items-center gap-1.5 rounded-md border border-[rgba(var(--line),0.95)] px-3 py-1.5 font-semibold text-[rgb(var(--ink))] transition hover:bg-[rgba(var(--line),0.35)]"
          data-bibtex={links.bibtex}
        >
          <Clipboard class="size-4" aria-hidden="true" />
          <span class="copy-label">Copy BibTeX</span>
        </button>
      )
    }
  </div>
</article>
