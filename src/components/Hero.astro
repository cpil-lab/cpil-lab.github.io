---
import { ArrowRight, Users } from 'lucide-astro';
import { withBase } from '../lib/paths';

interface Link {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryCta?: Link;
  secondaryCta?: Link;
  image?: string;
}

const {
  eyebrow = 'Research lab',
  title,
  description,
  primaryCta,
  secondaryCta,
  image = '/images/brand/cpil-hero.png',
} = Astro.props;
---

<section class="overflow-hidden border-b border-[rgba(var(--line),0.78)]">
  <div class="section-shell grid min-h-[calc(100vh-4rem)] items-center gap-10 py-14 md:min-h-[720px] lg:grid-cols-[0.9fr_1.1fr] lg:py-20">
    <div class="max-w-3xl">
      <p class="inline-flex items-center gap-2 rounded-md border border-[rgba(var(--line),0.9)] bg-[rgb(var(--surface-raised))] px-3 py-1 text-sm font-semibold text-[rgb(var(--accent-strong))]">
        <Users class="size-4" aria-hidden="true" />
        {eyebrow}
      </p>
      <h1 class="mt-6 max-w-4xl text-4xl font-bold leading-tight text-[rgb(var(--ink))] sm:text-5xl lg:text-6xl">
        {title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[rgb(var(--muted))]">
        {description}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        {
          primaryCta && (
            <a
              href={withBase(primaryCta.href)}
              class="inline-flex min-h-11 items-center gap-2 rounded-md bg-[rgb(var(--accent-strong))] px-5 py-3 text-sm font-bold text-white no-underline transition hover:translate-y-[-1px] hover:shadow-lg"
            >
              {primaryCta.label}
              <ArrowRight class="size-4" aria-hidden="true" />
            </a>
          )
        }
        {
          secondaryCta && (
            <a
              href={withBase(secondaryCta.href)}
              class="inline-flex min-h-11 items-center rounded-md border border-[rgba(var(--line),0.95)] bg-[rgb(var(--surface-raised))] px-5 py-3 text-sm font-bold text-[rgb(var(--ink))] no-underline transition hover:bg-[rgba(var(--line),0.35)]"
            >
              {secondaryCta.label}
            </a>
          )
        }
      </div>
    </div>

    <div class="relative">
      <img
        src={withBase(image)}
        alt="Abstract visualization of sensing, networks, and intelligent infrastructure"
        class="aspect-[4/3] w-full rounded-md border border-[rgba(var(--line),0.86)] object-cover shadow-2xl"
        loading="eager"
        decoding="async"
      />
      <div class="absolute -bottom-5 left-5 right-5 grid gap-3 rounded-md border border-[rgba(var(--line),0.85)] bg-[rgba(var(--surface-raised),0.92)] p-4 shadow-xl backdrop-blur md:left-auto md:w-72">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[rgb(var(--warm))]">Open positions</p>
        <p class="text-sm leading-6 text-[rgb(var(--muted))]">
          PhD students, postdocs, visiting scholars, and research interns are invited to connect.
        </p>
      </div>
    </div>
  </div>
</section>
