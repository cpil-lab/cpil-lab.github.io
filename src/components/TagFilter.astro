---
interface Props {
  label: string;
  name: string;
  options: string[];
  allLabel?: string;
}

const { label, name, options, allLabel = 'All' } = Astro.props;
---

<div class="grid gap-2">
  <p class="text-sm font-semibold text-[rgb(var(--ink))]">{label}</p>
  <div class="flex flex-wrap gap-2" data-filter-group={name}>
    <button
      type="button"
      class="filter-button rounded-md border border-[rgba(var(--line),0.95)] bg-[rgb(var(--ink))] px-3 py-2 text-sm font-semibold text-[rgb(var(--surface))]"
      data-filter-value="all"
      aria-pressed="true"
    >
      {allLabel}
    </button>
    {
      options.map((option) => (
        <button
          type="button"
          class="filter-button rounded-md border border-[rgba(var(--line),0.95)] px-3 py-2 text-sm font-semibold text-[rgb(var(--muted))] transition hover:bg-[rgba(var(--line),0.35)]"
          data-filter-value={option.toLowerCase()}
          aria-pressed="false"
        >
          {option}
        </button>
      ))
    }
  </div>
</div>
