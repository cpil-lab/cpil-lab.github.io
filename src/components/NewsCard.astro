---
import { ArrowUpRight, Calendar } from 'lucide-astro';
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/paths';

interface Props {
  item: CollectionEntry<'news'>;
}

const { item } = Astro.props;
const { title, shortTitle, date, displayDate, category, tags, summary, sourceType, sourceUrl, image, link } = item.data;
const formattedDate = new Intl.DateTimeFormat('en', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(date);
const href = sourceUrl || link;
---

<article class="card grid h-full overflow-hidden">
  {
    image && (
      <img
        src={withBase(image)}
        alt=""
        class="aspect-[16/9] w-full object-cover"
        loading="lazy"
        decoding="async"
      />
    )
  }
  <div class="grid gap-4 p-5">
    <div class="flex flex-wrap items-center gap-3 text-sm font-semibold text-[rgb(var(--muted))]">
      <span class="inline-flex items-center gap-2">
        <Calendar class="size-4" aria-hidden="true" />
        <time datetime={date.toISOString()}>{displayDate || formattedDate}</time>
      </span>
      {category && <span class="rounded-md bg-[rgba(var(--line),0.5)] px-2.5 py-1 text-xs">{category}</span>}
    </div>
    <h3 class="text-xl font-bold text-[rgb(var(--ink))]">{shortTitle || title}</h3>
    <p class="text-sm leading-6 text-[rgb(var(--muted))]">{summary}</p>
    {
      tags.length > 0 && (
        <ul class="flex flex-wrap gap-2" aria-label={`${title} tags`}>
          {tags.slice(0, 4).map((tag) => (
            <li class="rounded-md bg-[rgba(var(--accent),0.09)] px-2.5 py-1 text-xs font-semibold text-[rgb(var(--accent-strong))]">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
    {
      href && (
        <a href={href} class="inline-flex items-center gap-1.5 text-sm font-semibold text-[rgb(var(--accent-strong))]">
          {sourceType ? `Read on ${sourceType}` : 'Read more'}
          <ArrowUpRight class="size-4" aria-hidden="true" />
        </a>
      )
    }
  </div>
</article>
