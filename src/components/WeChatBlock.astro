---
import { MessageCircle } from 'lucide-astro';
import { siteInfo } from '../data/site';
import { withBase } from '../lib/paths';
---

<article class="card p-6">
  <div class="flex items-start gap-3">
    <span class="grid size-10 shrink-0 place-items-center rounded-md bg-[rgba(var(--accent),0.1)] text-[rgb(var(--accent-strong))]">
      <MessageCircle class="size-5" aria-hidden="true" />
    </span>
    <div>
      <h2 class="text-2xl font-bold text-[rgb(var(--ink))]">WeChat</h2>
      <p class="mt-2 text-sm font-semibold text-[rgb(var(--accent-strong))]">{siteInfo.wechatName}</p>
    </div>
  </div>
  <div class="mt-5 grid place-items-center rounded-md border border-[rgba(var(--line),0.95)] bg-[rgba(var(--line),0.16)] p-4 text-center">
    <img
      src={withBase(siteInfo.wechatQrPath)}
      alt="WeChat QR code for CPIL"
      class="h-auto w-48 rounded-md border border-[rgba(var(--line),0.9)] bg-white object-contain"
      loading="lazy"
      decoding="async"
    />
    <p class="mt-3 text-sm font-semibold text-[rgb(var(--ink))]">Follow CPIL on WeChat</p>
  </div>
  <p class="mt-5 text-sm leading-7 text-[rgb(var(--muted))]">
    Follow CPIL on WeChat for Chinese-language updates about lab news, accepted papers, research highlights, recruitment opportunities, and technical insights.
  </p>
</article>
