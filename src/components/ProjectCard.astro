---
import { ArrowUpRight } from 'lucide-astro';
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/paths';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, shortDescription, longDescription, members, tags, image, links, status } = project.data;
---

<article
  class="project-card card grid h-full overflow-hidden transition duration-200 hover:-translate-y-0.5"
  data-tags={tags.join('|').toLowerCase()}
  data-status={status}
  data-title={title.toLowerCase()}
>
  <img
    src={withBase(image)}
    alt={`Visualization for ${title}`}
    class="aspect-[16/10] w-full object-cover"
    loading="lazy"
    decoding="async"
  />
  <div class="grid gap-4 p-5">
    <div class="flex items-start justify-between gap-4">
      <h3 class="text-xl font-bold text-[rgb(var(--ink))]">{title}</h3>
      <span class:list={[
        'rounded-md px-2.5 py-1 text-xs font-bold uppercase tracking-[0.08em]',
        status === 'active'
          ? 'bg-[rgba(var(--accent),0.12)] text-[rgb(var(--accent-strong))]'
          : 'bg-[rgba(var(--line),0.58)] text-[rgb(var(--muted))]',
      ]}>
        {status}
      </span>
    </div>
    <p class="text-sm leading-6 text-[rgb(var(--muted))]">{shortDescription}</p>
    <details class="group text-sm leading-6 text-[rgb(var(--muted))]">
      <summary class="cursor-pointer font-semibold text-[rgb(var(--accent-strong))]">More details</summary>
      <p class="mt-2">{longDescription}</p>
    </details>
    {
      members.length > 0 && (
        <p class="text-sm text-[rgb(var(--muted))]">
          <span class="font-semibold text-[rgb(var(--ink))]">Members:</span> {members.join(', ')}
        </p>
      )
    }
    {
      tags.length > 0 && (
        <ul class="flex flex-wrap gap-2" aria-label={`${title} topics`}>
          {tags.map((tag) => (
            <li class="rounded-md bg-[rgba(var(--warm),0.12)] px-2.5 py-1 text-xs font-semibold text-[rgb(var(--warm))]">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
    {
      links.length > 0 && (
        <div class="flex flex-wrap gap-3 text-sm">
          {links.map((link) => (
            <a href={link.url} class="inline-flex items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
              {link.label}
              <ArrowUpRight class="size-4" aria-hidden="true" />
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
