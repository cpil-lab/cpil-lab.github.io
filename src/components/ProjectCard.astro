---
import { ArrowRight, ArrowUpRight } from 'lucide-astro';
import type { CollectionEntry } from 'astro:content';
import { externalUrl, withBase } from '../lib/paths';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, shortDescription, longDescription, leaders, members, tags, image, links, status } = project.data;
const detailHref = withBase(`/projects/${project.id}/`);
const imageIsIcon = image.toLowerCase().endsWith('.svg') || image.toLowerCase().includes('logo');
---

<article
  class="project-card card grid h-full min-w-0 grid-rows-[auto_1fr] overflow-hidden"
  data-tags={tags.join('|').toLowerCase()}
  data-status={status}
  data-title={title.toLowerCase()}
>
  <div class="relative aspect-[16/10] w-full overflow-hidden bg-[#f5f5f7]">
    {
      imageIsIcon ? (
        <img
          src={withBase(image)}
          alt={`Visualization for ${title}`}
          class="absolute left-1/2 top-1/2 h-[70%] max-h-44 w-auto max-w-[72%] -translate-x-1/2 -translate-y-1/2 object-contain"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <img
          src={withBase(image)}
          alt={`Visualization for ${title}`}
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>
  <div class="flex h-full min-w-0 flex-col gap-4 p-5">
    <div class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-start gap-3">
      <h3 class="min-w-0 text-xl font-bold leading-7 text-[rgb(var(--ink))]">
        <a href={detailHref} class="text-inherit no-underline hover:text-[rgb(var(--accent-strong))]">
          {title}
        </a>
      </h3>
      <span class:list={[
        'shrink-0 rounded-md px-2.5 py-1 text-xs font-semibold uppercase tracking-[0.08em]',
        status === 'active'
          ? 'bg-[rgba(var(--accent),0.12)] text-[rgb(var(--accent-strong))]'
          : 'bg-[rgba(var(--line),0.58)] text-[rgb(var(--muted))]',
      ]}>
        {status}
      </span>
    </div>
    <p class="min-w-0 text-sm leading-6 text-[rgb(var(--muted))]">{shortDescription}</p>
    <details class="group min-w-0 text-sm leading-6 text-[rgb(var(--muted))]">
      <summary class="cursor-pointer font-semibold text-[rgb(var(--accent-strong))]">Project summary</summary>
      <p class="mt-2">{longDescription}</p>
    </details>
    {
      leaders.length > 0 && (
        <p class="min-w-0 text-sm leading-6 text-[rgb(var(--muted))]">
          <span class="font-semibold text-[rgb(var(--ink))]">Lead:</span> {leaders.join(', ')}
        </p>
      )
    }
    {
      members.length > 0 && (
        <p class="min-w-0 text-sm leading-6 text-[rgb(var(--muted))]">
          <span class="font-semibold text-[rgb(var(--ink))]">Members:</span> {members.join(', ')}
        </p>
      )
    }
    {
      tags.length > 0 && (
        <ul class="flex min-w-0 flex-wrap gap-2" aria-label={`${title} topics`}>
          {tags.map((tag) => (
            <li class="max-w-full rounded-md bg-[rgba(var(--line),0.5)] px-2.5 py-1 text-xs font-semibold text-[rgb(var(--muted))]">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
    <div class="mt-auto flex min-w-0 flex-wrap gap-3 pt-1 text-sm">
      <a href={detailHref} class="inline-flex items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
        Details
        <ArrowRight class="size-4" aria-hidden="true" />
      </a>
      {links.map((link) => (
        <a href={externalUrl(link.url)} class="inline-flex min-w-0 items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
          {link.label}
          <ArrowUpRight class="size-4" aria-hidden="true" />
        </a>
      ))}
    </div>
  </div>
</article>
