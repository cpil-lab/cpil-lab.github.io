---
import { ArrowRight, Mail } from 'lucide-astro';
import { navItems, siteInfo } from '../data/site';
import { withBase } from '../lib/paths';
---

<footer class="mt-20 border-t border-[rgba(var(--line),0.86)] bg-[rgb(var(--surface-raised))]">
  <div class="section-shell grid gap-10 py-12 md:grid-cols-[1.2fr_0.8fr_0.8fr]">
    <div>
      <p class="text-sm font-bold text-[rgb(var(--ink))]">{siteInfo.shortName}</p>
      <p class="mt-3 max-w-xl text-sm leading-7 text-[rgb(var(--muted))]">
        {siteInfo.name}<br />
        Led by {siteInfo.director}<br />
        {siteInfo.platforms.join(' · ')}
      </p>
      <a
        href={`mailto:${siteInfo.websiteSupportEmail}`}
        class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-[rgb(var(--accent-strong))]"
      >
        <Mail class="size-4" aria-hidden="true" />
        Website support: {siteInfo.websiteSupportEmail}
      </a>
    </div>

    <div>
      <p class="text-sm font-semibold text-[rgb(var(--ink))]">Pages</p>
      <ul class="mt-3 grid gap-2 text-sm">
        {
          navItems.map((item) => (
            <li>
              <a href={withBase(item.href)} class="text-[rgb(var(--muted))] hover:text-[rgb(var(--accent-strong))]">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold text-[rgb(var(--ink))]">Lab Updates</p>
      <p class="mt-3 text-sm leading-7 text-[rgb(var(--muted))]">
        WeChat: {siteInfo.wechatName}
      </p>
      <a href={withBase('/join/')} class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[rgb(var(--accent-strong))]">
        Join CPIL
        <ArrowRight class="size-4" aria-hidden="true" />
      </a>
      <a href={withBase('/admin/')} class="mt-3 block text-sm font-semibold text-[rgb(var(--muted))] hover:text-[rgb(var(--accent-strong))]">
        Content Admin
      </a>
    </div>
  </div>
  <div class="border-t border-[rgba(var(--line),0.7)] py-5">
    <div class="section-shell text-xs text-[rgb(var(--muted))]">
      Copyright {new Date().getFullYear()} {siteInfo.name}.
    </div>
  </div>
</footer>
