---
import { Moon, Sun } from 'lucide-astro';
---

<button
  id="theme-toggle"
  type="button"
  class="grid size-10 place-items-center rounded-md border border-[rgba(var(--line),0.9)] text-[rgb(var(--ink))] transition hover:bg-[rgba(var(--line),0.35)]"
  aria-label="Toggle color theme"
  title="Toggle color theme"
>
  <Sun class="size-5 dark:hidden" aria-hidden="true" />
  <Moon class="hidden size-5 dark:block" aria-hidden="true" />
</button>

<script is:inline>
  (() => {
    const button = document.getElementById('theme-toggle');
    if (!button) return;

    button.addEventListener('click', () => {
      const nextTheme = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
      document.documentElement.classList.toggle('dark', nextTheme === 'dark');
      document.documentElement.dataset.theme = nextTheme;
      localStorage.setItem('cpil-theme', nextTheme);
    });
  })();
</script>
